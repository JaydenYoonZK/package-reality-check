{
  "name": "package-reality-check",
  "version": "1.5.10",
  "description": "Check that your dependencies actually exist and are plausibly legitimate. Catches AI-hallucinated (slopsquatted) packages and fresh typosquats before you install them. Browser tool and zero-dependency CLI.",
  "type": "module",
  "bin": {
    "package-reality-check": "bin/cli.mjs",
    "prc": "bin/cli.mjs"
  },
  "files": [
    "bin/",
    "docs/checker.js",
    "docs/registry.js"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test",
    "start": "node bin/cli.mjs",
    "serve": "python3 -m http.server 8322 -d docs",
    "coverage": "node --test --experimental-test-coverage"
  },
  "keywords": [
    "supply-chain-security",
    "slopsquatting",
    "typosquatting",
    "npm",
    "pypi",
    "dependency-check",
    "package-hallucination",
    "ai-code",
    "cli",
    "security"
  ],
  "license": "MIT",
  "author": "Jayden Yoon ZK",
  "repository": {
    "type": "git",
    "url": "https://github.com/JaydenYoonZK/package-reality-check.git"
  },
  "bugs": {
    "url": "https://github.com/JaydenYoonZK/package-reality-check/issues"
  },
  "homepage": "https://jaydenyoonzk.github.io/package-reality-check/"
}
